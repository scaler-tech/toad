# Toad configuration
# Copy to .toad.yaml and fill in your values
# Place in repo root or globally at ~/.toad/config.yaml

slack:
  # Tokens (can also use TOAD_SLACK_APP_TOKEN / TOAD_SLACK_BOT_TOKEN env vars)
  app_token: "xapp-1-..."
  bot_token: "xoxb-..."

  # Channels to monitor (use channel IDs, not names)
  channels:
    - "C0123456789"

  # What triggers Toad
  triggers:
    emoji: "frog"              # React with 🐸 to trigger
    keywords:                  # These in messages trigger Toad
      - "toad fix"
      - "toad help"

repos:
  - name: "my-app"                 # Short name to identify this repo
    path: "/path/to/repo"          # Absolute or relative path (resolved to absolute)
    test_command: "go test ./..."
    lint_command: "golangci-lint run"
    default_branch: "main"
    auto_merge: false              # Enable auto-merge on PRs (requires repo setting)
    # Per-service validation for monorepos
    # services:
    #   - path: "web-app"
    #     test_command: "make test"
    #     lint_command: "make stan && make cs"
  # Add more repos:
  # - name: "frontend"
  #   path: "/path/to/frontend"
  #   primary: true                # Designate one as fallback when repo can't be determined

limits:
  max_concurrent: 2            # Max parallel tadpoles
  max_turns: 30                # Claude Code max turns per tadpole
  timeout_minutes: 10          # Kill tadpole after this
  max_files_changed: 5         # Abort if too many files touched
  max_budget_usd: 1.00         # Per-tadpole cost cap
  max_retries: 1               # Test/lint failure retries

triage:
  model: "haiku"               # Fast + cheap for classification
  auto_spawn: false            # Require explicit 🐸 trigger for code changes

claude:
  model: "sonnet"              # Model for tadpole code runs
  # append_system_prompt: ""   # Extra instructions for all tadpole runs

digest:
  enabled: false               # Opt-in batch analysis (Toad King)
  # dry_run: false             # Collect + analyze but skip spawn/notify
  batch_minutes: 5
  min_confidence: 0.95
  max_auto_spawn_hour: 3
  allowed_categories: ["bug"]
  max_est_size: "small"

issue_tracker:
  enabled: false               # Enable issue tracker integration
  provider: "linear"           # "linear" (only supported provider for now)
  # api_token: ""              # Or use TOAD_LINEAR_API_TOKEN env var
  # team_id: ""                # Linear team ID for issue creation
  create_issues: false         # Opt-in: create issues for opportunities without one
  # bug_label_id: ""           # Optional Linear label for bugs
  # feature_label_id: ""       # Optional Linear label for features

log:
  level: "info"                # debug, info, warn, error
  # file: "~/.toad/toad.log"
